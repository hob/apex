---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    name: 'Exterior & Interior Detail',
    price: '$200',
    isBase: true,
    description:
      'Our comprehensive base detail covers a full exterior hand wash, clay bar treatment, interior vacuum, surface wipe-down, and window cleaning inside and out. The foundation of every great detail.',
    icon: '✦',
  },
  {
    name: 'Full Wax & Shine',
    price: '+$390',
    isBase: false,
    description:
      'Carnauba wax application by hand for deep, long-lasting protection and a mirror-like gloss. Includes paint decontamination and a final buff for showroom-quality shine.',
    icon: '◈',
  },
  {
    name: 'Leather Conditioning',
    price: '+$100',
    isBase: false,
    description:
      'Professional-grade leather cleaner and conditioner applied to all leather surfaces. Restores softness, prevents cracking, and brings life back to faded or worn leather.',
    icon: '◉',
  },
  {
    name: 'Engine Bay Detail',
    price: '+$150',
    isBase: false,
    description:
      'Thorough degreasing and cleaning of the engine bay. All plastic and rubber components are dressed, leaving your engine bay looking as good under the hood as on the road.',
    icon: '⬡',
  },
  {
    name: 'Rim Detail & Tire Shine',
    price: '+$30',
    isBase: false,
    description:
      'Individual rim cleaning to remove brake dust and grime, followed by a premium tire dressing for that deep, dark satin finish that completes the look of any vehicle.',
    icon: '◎',
  },
  {
    name: 'Window Rain Protectant',
    price: '+$30',
    isBase: false,
    description:
      'Hydrophobic coating applied to all exterior glass. Water beads and sheets off at speed, dramatically improving wet-weather visibility and reducing water spotting.',
    icon: '◇',
  },
];
---

<Layout
  title="Apex Detail — Premium Automotive Detailing"
  description="Apex Detail brings precision, passion, and flawless results to every vehicle. Exterior & interior detailing, engine bay, wax, leather conditioning, and more. Call 908-878-6125."
>
  <!-- ============================
       HERO
  ============================= -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero-bg-grid" aria-hidden="true"></div>
    <div class="hero-glow" aria-hidden="true"></div>

    <div class="container hero-content">
      <div class="hero-badge">Now Open &amp; Serving Your Area</div>

      <h1 class="hero-heading" id="hero-heading">
        Where Every<br />
        <span class="heading-accent">Detail</span> Matters.
      </h1>

      <p class="hero-sub">
        Apex Detail brings a higher standard of automotive care to your vehicle — from restoring
        shine to protecting every surface. Precision-driven results, every time.
      </p>

      <div class="hero-actions">
        <a href="tel:9088786125" class="btn btn-primary btn-lg">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8 19.79 19.79 0 01.05 2.18 2 2 0 012 .05h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"
            ></path>
          </svg>
          Get a Quote
        </a>
        <a href="#services" class="btn btn-ghost btn-lg">
          See Services
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </a>
      </div>

      <div class="hero-stats" aria-label="Key facts">
        <div class="stat">
          <span class="stat-value">$200</span>
          <span class="stat-label">Starting Price</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat">
          <span class="stat-value">6+</span>
          <span class="stat-label">Services Offered</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat">
          <span class="stat-value">100%</span>
          <span class="stat-label">Satisfaction Focus</span>
        </div>
      </div>
    </div>

    <div class="hero-scroll-hint" aria-hidden="true">
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>
  </section>

  <!-- ============================
       ABOUT
  ============================= -->
  <section class="about-section" id="about" aria-labelledby="about-heading">
    <div class="container">
      <div class="section-label" aria-hidden="true">Our Story</div>
      <h2 class="section-heading" id="about-heading">Built on Precision &amp; Passion</h2>

      <div class="about-layout">
        <div class="about-text">
          <p>
            Apex Detail is officially open and ready to redefine what true automotive care looks
            like. Built on precision, passion, and a commitment to flawless results, Apex Detail
            brings a higher standard of detailing to the community.
          </p>
          <p>
            From restoring shine to protecting every surface, our mission is to elevate your vehicle
            to its absolute peak. Today marks the beginning of a business dedicated to quality,
            trust, and craftsmanship — welcome to Apex Detail, where every detail matters.
          </p>
        </div>

        <div class="about-pillars" aria-label="Our values">
          <article class="pillar-card">
            <div class="pillar-icon" aria-hidden="true">
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            </div>
            <h3>Precision</h3>
            <p>Every inch of your vehicle is treated with focused, meticulous care.</p>
          </article>

          <article class="pillar-card">
            <div class="pillar-icon" aria-hidden="true">
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"
                ></path>
              </svg>
            </div>
            <h3>Passion</h3>
            <p>We love what we do — and it shows in every detail, every time.</p>
          </article>

          <article class="pillar-card">
            <div class="pillar-icon" aria-hidden="true">
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              </svg>
            </div>
            <h3>Trust</h3>
            <p>Honest pricing, consistent quality, and respect for your vehicle.</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================
       SERVICES
  ============================= -->
  <section class="services-section" id="services" aria-labelledby="services-heading">
    <div class="container">
      <div class="section-label" aria-hidden="true">Pricing & Services</div>
      <h2 class="section-heading" id="services-heading">What We Offer</h2>
      <p class="section-sub">
        Starting at <strong>$200</strong> — pricing ranges from <strong>$200–$800</strong> depending
        on vehicle type and services selected. Every package begins with our base exterior &amp; interior
        detail.
      </p>

      <!-- Base Service -->
      <div class="base-service-wrapper" aria-label="Base service">
        <article class="base-service-card">
          <div class="base-service-inner">
            <div class="base-badge">Base Package</div>
            <h3 class="base-name">{services[0].name}</h3>
            <p class="base-desc">{services[0].description}</p>
          </div>
          <div class="base-price-block">
            <span class="base-price-label">Starting at</span>
            <span class="base-price">{services[0].price}</span>
            <span class="base-price-note">+ add-ons below</span>
          </div>
        </article>
      </div>

      <!-- Add-on Services -->
      <div class="addons-label">
        <span>Customize with Add-ons</span>
      </div>

      <ul class="services-grid" role="list" aria-label="Add-on services">
        {
          services.slice(1).map((service) => (
            <li>
              <article class="service-card">
                <div class="service-icon" aria-hidden="true">
                  {service.icon}
                </div>
                <div class="service-body">
                  <h3 class="service-name">{service.name}</h3>
                  <p class="service-desc">{service.description}</p>
                </div>
                <div class="service-price" aria-label={`Price: ${service.price}`}>
                  {service.price}
                </div>
              </article>
            </li>
          ))
        }
      </ul>

      <!-- Featured: Super Clean -->
      <article class="featured-card" aria-labelledby="super-clean-heading">
        <div class="featured-ribbon" aria-hidden="true">Featured Add-on</div>
        <div class="featured-content">
          <div class="featured-header">
            <div class="featured-title-group">
              <span class="featured-eyebrow">Signature Service</span>
              <h3 class="featured-name" id="super-clean-heading">Super Clean</h3>
              <p class="featured-subtitle">Engine Bay Detail</p>
            </div>
            <div class="featured-price-block">
              <span class="featured-price">+$150</span>
              <span class="featured-price-label">add-on</span>
            </div>
          </div>
          <p class="featured-desc">
            A full engine bay wash from bottom to top using our specialized engine bay solution.
            Every component is carefully degreased, rinsed, and dried — leaving your engine bay
            spotless and protected. This is the deep-clean treatment your engine deserves.
          </p>
          <a href="tel:9088786125" class="btn btn-featured">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path
                d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8 19.79 19.79 0 01.05 2.18 2 2 0 012 .05h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"
              ></path>
            </svg>
            Book Super Clean
          </a>
        </div>
      </article>
    </div>
  </section>

  <!-- ============================
       CONTACT
  ============================= -->
  <section class="contact-section" id="contact" aria-labelledby="contact-heading">
    <div class="container">
      <div class="section-label" aria-hidden="true">Get In Touch</div>
      <h2 class="section-heading" id="contact-heading">Ready to Elevate Your Ride?</h2>
      <p class="section-sub">
        Call or text us to schedule your detail or get a custom quote. Pricing ranges from
        <strong>$200–$800</strong> based on vehicle size and selected services.
      </p>

      <div class="contact-cards">
        <article class="contact-card" aria-label="Primary phone number">
          <div class="contact-card-icon" aria-hidden="true">
            <svg
              width="28"
              height="28"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8 19.79 19.79 0 01.05 2.18 2 2 0 012 .05h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"
              ></path>
            </svg>
          </div>
          <div class="contact-card-info">
            <span class="contact-card-label">Call or Text</span>
            <a href="tel:9088786125" class="contact-phone-number">908-878-6125</a>
          </div>
          <a href="tel:9088786125" class="btn btn-primary contact-btn" aria-label="Call 908-878-6125"
            >Call Now</a
          >
        </article>

        <article class="contact-card" aria-label="Secondary phone number">
          <div class="contact-card-icon" aria-hidden="true">
            <svg
              width="28"
              height="28"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8 19.79 19.79 0 01.05 2.18 2 2 0 012 .05h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"
              ></path>
            </svg>
          </div>
          <div class="contact-card-info">
            <span class="contact-card-label">Call or Text</span>
            <a href="tel:3057726418" class="contact-phone-number">305-772-6418</a>
          </div>
          <a href="tel:3057726418" class="btn btn-primary contact-btn" aria-label="Call 305-772-6418"
            >Call Now</a
          >
        </article>
      </div>

      <div class="contact-note">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="12"></line>
          <line x1="12" y1="16" x2="12.01" y2="16"></line>
        </svg>
        <p>
          Quotes are customized to your vehicle. We'll walk you through every option to get you the
          best results at the right price.
        </p>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ==============================
     Shared Section Styles
  ============================== */
  .section-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }

  .section-heading {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .section-sub {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 52ch;
    line-height: 1.7;
    margin-bottom: var(--space-xl);
  }

  .section-sub strong {
    color: var(--color-primary);
    font-weight: 700;
  }

  /* ==============================
     Buttons
  ============================== */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-weight: 700;
    border-radius: var(--radius-sm);
    cursor: pointer;
    border: none;
    text-decoration: none;
    transition: background-color var(--transition-fast), color var(--transition-fast),
      transform var(--transition-fast), box-shadow var(--transition-fast),
      border-color var(--transition-fast);
    white-space: nowrap;
  }

  .btn:active {
    transform: translateY(1px) !important;
  }

  .btn-lg {
    padding: 0.875rem 2rem;
    font-size: 1rem;
  }

  .btn-primary {
    background-color: var(--color-primary);
    color: var(--color-dark);
  }

  .btn-primary:hover,
  .btn-primary:focus-visible {
    background-color: var(--color-primary-light);
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow);
  }

  .btn-ghost {
    background-color: transparent;
    color: var(--color-text-muted);
    border: 1.5px solid var(--color-border-subtle);
  }

  .btn-ghost:hover,
  .btn-ghost:focus-visible {
    color: var(--color-text);
    border-color: rgba(255, 255, 255, 0.25);
    background-color: rgba(255, 255, 255, 0.05);
    transform: translateY(-2px);
  }

  .btn-featured {
    background-color: var(--color-dark);
    color: var(--color-primary);
    border: 1.5px solid var(--color-primary);
    padding: 0.75rem 1.75rem;
    font-size: 0.95rem;
    border-radius: var(--radius-sm);
  }

  .btn-featured:hover,
  .btn-featured:focus-visible {
    background-color: var(--color-primary);
    color: var(--color-dark);
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow);
  }

  /* ==============================
     Hero Section
  ============================== */
  .hero {
    position: relative;
    min-height: calc(100dvh - var(--nav-height));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: var(--space-2xl) 0 var(--space-xl);
  }

  .hero-bg-grid {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(rgba(38, 198, 218, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(38, 198, 218, 0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 0%, black 0%, transparent 100%);
    pointer-events: none;
  }

  .hero-glow {
    position: absolute;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: min(700px, 120vw);
    height: min(700px, 120vw);
    background: radial-gradient(circle, rgba(38, 198, 218, 0.12) 0%, transparent 65%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    background-color: rgba(38, 198, 218, 0.1);
    border: 1px solid rgba(38, 198, 218, 0.25);
    border-radius: 100px;
  }

  .hero-badge::before {
    content: '';
    display: block;
    width: 6px;
    height: 6px;
    background-color: var(--color-primary);
    border-radius: 50%;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.5;
      transform: scale(0.7);
    }
  }

  .hero-heading {
    font-size: clamp(2.5rem, 8vw, 5.5rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--color-text);
    max-width: 14ch;
  }

  .heading-accent {
    color: var(--color-primary);
    position: relative;
  }

  .hero-sub {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    color: var(--color-text-muted);
    max-width: 48ch;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    justify-content: center;
    margin-top: var(--space-xs);
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    margin-top: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--color-text-subtle);
    font-weight: 500;
    white-space: nowrap;
  }

  .stat-divider {
    width: 1px;
    height: 36px;
    background-color: var(--color-border-subtle);
    flex-shrink: 0;
  }

  .hero-scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: var(--color-text-subtle);
    animation: bounce 2s ease-in-out infinite;
  }

  @keyframes bounce {
    0%,
    100% {
      transform: translateX(-50%) translateY(0);
    }
    50% {
      transform: translateX(-50%) translateY(6px);
    }
  }

  @media (max-width: 480px) {
    .hero-stats {
      gap: var(--space-md);
      padding: var(--space-sm) var(--space-md);
    }

    .stat-value {
      font-size: 1.25rem;
    }
  }

  /* ==============================
     About Section
  ============================== */
  .about-section {
    padding: var(--space-2xl) 0;
    background-color: var(--color-dark-2);
    border-top: 1px solid var(--color-border-subtle);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .about-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .about-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .about-text p {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    line-height: 1.8;
  }

  .about-pillars {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .pillar-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    padding: var(--space-md);
    background-color: var(--color-dark-3);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .pillar-card:hover {
    border-color: var(--color-border);
